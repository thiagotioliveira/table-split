<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="rootLogLevel" source="logging.level.ROOT" defaultValue="INFO"/>
    <springProperty scope="context" name="appLogLevel" source="logging.level.dev.thiagooliveira" defaultValue="INFO"/>
    <springProperty scope="context" name="hibernateSqlLevel" source="logging.level.org.hibernate.SQL" defaultValue="INFO"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%logger{36}] %msg%n%xThrowable{full}</pattern>
        </encoder>
    </appender>

    <!-- Tomcat/Catalina: log servlet exceptions at ERROR, suppress lower-level noise -->
    <logger name="org.apache.catalina" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Spring Web: log dispatcher and servlet exceptions at ERROR -->
    <logger name="org.springframework.web" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Spring Web MVC servlet handler: ensure full stack traces surface at ERROR -->
    <logger name="org.springframework.web.servlet" level="ERROR" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Spring transactions: keep suppressed as per application.yaml -->
    <logger name="org.springframework.transaction" level="OFF" additivity="false"/>

    <!-- Hibernate SQL: driven by application.yaml property -->
    <logger name="org.hibernate.SQL" level="${hibernateSqlLevel}" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="${hibernateSqlLevel}" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Liquibase: keep suppressed as per application.yaml -->
    <logger name="liquibase" level="OFF" additivity="false"/>

    <!-- Application code -->
    <logger name="dev.thiagooliveira" level="${appLogLevel}" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <root level="${rootLogLevel}">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
