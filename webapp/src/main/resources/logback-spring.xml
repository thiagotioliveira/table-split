<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="rootLogLevel" source="logging.level.ROOT" defaultValue="INFO"/>
    <springProperty scope="context" name="appLogLevel" source="logging.level.dev.thiagooliveira" defaultValue="INFO"/>
    <springProperty scope="context" name="hibernateSqlLevel" source="logging.level.org.hibernate.SQL" defaultValue="INFO"/>

    <!-- Appender para Console (Legível por humanos) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.out</target>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%logger{36}] %msg%n%xThrowable{full}</pattern>
        </encoder>
    </appender>

    <!-- Appender para Erros no System.err (Ajuda a infraestrutura a detectar erros críticos) -->
    <appender name="CONSOLE_ERROR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%logger{36}] %msg%n%xThrowable{full}</pattern>
        </encoder>
    </appender>

    <!-- Appender JSON (Ideal para Produção/Cloud) -->
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdc>true</includeMdc>
            <includeContext>true</includeContext>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <level>severity</level>
                <logger>logger</logger>
                <thread>thread</thread>
                <message>message</message>
            </fieldNames>
        </encoder>
    </appender>

    <!-- Loggers de Terceiros -->
    <logger name="org.apache.catalina" level="ERROR"/>
    <logger name="org.springframework.web" level="ERROR"/>
    <logger name="org.springframework.web.servlet" level="ERROR"/>
    <logger name="org.springframework.transaction" level="OFF"/>
    <logger name="org.hibernate.SQL" level="${hibernateSqlLevel}"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="${hibernateSqlLevel}"/>
    <logger name="liquibase" level="OFF"/>

    <!-- Loggers da Aplicação -->
    <logger name="dev.thiagooliveira" level="${appLogLevel}"/>
    <logger name="org.thymeleaf" level="WARN"/>

    <!-- Configuração por Perfil -->

    <!-- Perfil de Produção: JSON + Erros no Stderr -->
    <springProfile name="prod">
        <root level="${rootLogLevel}">
            <appender-ref ref="JSON"/>
            <appender-ref ref="CONSOLE_ERROR"/>
        </root>
    </springProfile>

    <!-- Perfil Default/Dev: Console legível -->
    <springProfile name="!prod">
        <root level="${rootLogLevel}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="CONSOLE_ERROR"/>
        </root>
    </springProfile>

</configuration>
